// Define your database connection
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // stored in .env
}

generator client {
  provider = "prisma-client-js"
}

// University model
model University {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  applicationOpen DateTime
  applicationClose DateTime
  requiredDocs    String[]  // e.g. ["Matric Certificate", "ID", "Proof of Payment"]
  faqs            FAQ[]
}

// FAQ model for career guidance and general advice
model FAQ {
  id        Int      @id @default(autoincrement())
  category  String   // "Deadlines", "Documents", "Career"
  question  String
  answer    String
  university University? @relation(fields: [universityId], references: [id])
  universityId Int?
}